{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"target": "ES2022",
		"module": "CommonJS",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node"],
		"paths": {
			"@src/*": ["../src/*"]
		}
	},
	"include": ["./**/*", "../jest.config.ts"]
}
