{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"composite": true,
		"declaration": true,
		"module": "NodeNext",
		"rootDir": ".",
		"outDir": "dist",
		"newLine": "lf",
		"esModuleInterop": true,		
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"paths": {
			"@src/*": ["./src/*"]
		},
		"types": [
			"node"
		]
	  },
	  "exclude": ["dist", "node_modules"]
}
